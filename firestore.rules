rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.email == "kimhazard25@gmail.com";
    }

    match /applications/{applicationId} {
      allow create: if true;
      allow read: if isAdmin() || (signedIn() && resource.data.email == request.auth.token.email);
      allow update: if isAdmin() || (signedIn() && resource.data.email == request.auth.token.email);
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read, update: if isAdmin() || (signedIn() && studentId == request.auth.uid);
      allow create: if signedIn();
      allow delete: if isAdmin();
    }

    match /universities/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /courses/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scholarships/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{id} {
      allow read, write: if isAdmin();
    }
  }
}
